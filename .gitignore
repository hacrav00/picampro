# PiCamPro — .gitignore

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# Logs & runtime data
logs/
*.log

# Captured media (kept on the Pi, not in git)
captures/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Temporary files
*.tmp
*.bak
